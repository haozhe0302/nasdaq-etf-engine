# ══════════════════════════════════════════════
# HQQQ Phase 2 — Environment Variables
# ══════════════════════════════════════════════
# Copy this file to .env and fill in real values.
# All other values have sensible local-dev defaults.
#
# Phase 2 services use .NET hierarchical configuration
# with __ (double-underscore) as the section separator.
# Example: Tiingo__ApiKey maps to { "Tiingo": { "ApiKey": "..." } }

# ── Operating mode ────────────────────────────
# OperatingMode is now a logging-posture tag only. Phase 2 runtime has a
# single self-sufficient path; the legacy monolith (hqqq-api) is retained
# in the repo as reference code and does NOT participate in Phase 2
# runtime. Leave at `standalone` for clarity in logs; the enum still
# accepts `hybrid` for backward compatibility but both values drive the
# same runtime behaviour.
HQQQ_OPERATING_MODE=standalone

# ── Tiingo Market Data (hqqq-ingress) ────────
# Required. hqqq-ingress fails fast on a missing/placeholder key —
# there is no stub or hybrid path.
Tiingo__ApiKey=YOUR_TIINGO_API_KEY_HERE
Tiingo__WsUrl=wss://api.tiingo.com/iex
Tiingo__RestBaseUrl=https://api.tiingo.com/iex
Tiingo__RestPollingIntervalSeconds=5
Tiingo__ReconnectBaseDelaySeconds=2
# Optional override — leave empty in normal runs. Ingress derives its
# active symbol universe from refdata.basket.active.v1. The override is
# only used as a bootstrap fallback (tests / isolated runs) when the
# basket topic hasn't delivered its first event within StartupWaitSeconds.
# Tiingo__Symbols=AAPL,MSFT,NVDA,AMZN,META

# ── Ingress basket consumer ──────────────────
# hqqq-ingress consumes refdata.basket.active.v1 and drives the Tiingo
# subscribe/unsubscribe off the basket event. Defaults are sensible.
# Ingress__Basket__Topic=refdata.basket.active.v1
# Ingress__Basket__ConsumerGroup=ingress-baskets
# Ingress__Basket__StartupWaitSeconds=60

# ── Reference data (active-basket pipeline) ───
# hqqq-reference-data owns the active basket. Default posture: live
# holdings disabled, composite goes straight to the committed ~100-name
# fallback seed shipped in
# src/services/hqqq-reference-data/Resources/basket-seed.json.

# Flip to File/Http to plug in a real holdings drop without rebuilding:
# ReferenceData__LiveHoldings__SourceType=None   # None | File | Http
# ReferenceData__LiveHoldings__FilePath=
# ReferenceData__LiveHoldings__HttpUrl=
# ReferenceData__LiveHoldings__HttpTimeoutSeconds=10
# ReferenceData__LiveHoldings__StaleAfterHours=0

# Refresh cadence knobs.
# ReferenceData__Refresh__IntervalSeconds=600
# ReferenceData__Refresh__RepublishIntervalSeconds=300
# ReferenceData__Refresh__StartupMaxWaitSeconds=30

# Validation policy (strict rejects malformed live snapshots → falls back to seed).
# ReferenceData__Validation__Strict=true
# ReferenceData__Validation__MinConstituents=50
# ReferenceData__Validation__MaxConstituents=150

# Override the deterministic fallback seed path (empty = embedded resource).
# ReferenceData__SeedPath=

# Override the published topic name (empty = refdata.basket.active.v1).
# ReferenceData__Publish__TopicName=

# Publish-health readiness thresholds. /healthz/ready returns 503 (Degraded
# or Unhealthy) when the Kafka publisher is failing, so operators see the
# outage instead of a silently-healthy service.
# ReferenceData__PublishHealth__FirstActivationGraceSeconds=60
# ReferenceData__PublishHealth__DegradedAfterConsecutiveFailures=1
# ReferenceData__PublishHealth__UnhealthyAfterConsecutiveFailures=5
# ReferenceData__PublishHealth__MaxSilenceSeconds=900

# ── Phase-2-native corporate-action adjustment ───
# hqqq-reference-data applies split / reverse-split / ticker-rename
# adjustments to the basket BEFORE publishing. The composite provider
# reads a deterministic JSON file first (default: empty embedded seed
# at Resources/corporate-actions-seed.json); operators can point at a
# forked file without rebuilding the image. Tiingo overlay is opt-in.
# Supported scope (honest): splits, reverse splits, ticker renames,
# constituent add/remove detection, scale-factor continuity.
# Out of scope: dividends, spin-offs, mergers, acquisitions.
# ReferenceData__CorporateActions__LookbackDays=365
# ReferenceData__CorporateActions__File__Path=
# ReferenceData__CorporateActions__Tiingo__Enabled=false
# ReferenceData__CorporateActions__Tiingo__ApiKey=
# ReferenceData__CorporateActions__Tiingo__BaseUrl=https://api.tiingo.com/tiingo/daily

# ── Kafka ─────────────────────────────────────
Kafka__BootstrapServers=localhost:9092
Kafka__ClientId=hqqq-local
Kafka__ConsumerGroupPrefix=hqqq
# When targeting Azure Event Hubs Kafka (topics must be pre-created on
# the namespace; the shared bootstrap helper switches to metadata-only
# validation when EnableTopicBootstrap=false). Leave commented out for
# local docker-compose — defaults stay Plaintext / topic-creating.
# Kafka__SecurityProtocol=SaslSsl
# Kafka__SaslMechanism=Plain
# Kafka__SaslUsername=$ConnectionString
# Kafka__SaslPassword=Endpoint=sb://<ns>.servicebus.windows.net/;SharedAccessKeyName=...;SharedAccessKey=...
# Kafka__EnableTopicBootstrap=false

# ── Redis ─────────────────────────────────────
Redis__Configuration=localhost:6379

# ── TimescaleDB ───────────────────────────────
Timescale__ConnectionString=Host=localhost;Port=5432;Database=hqqq;Username=admin;Password=changeme

# ── Gateway (hqqq-gateway) ────────────────────
# Default posture: per-endpoint data sources wired directly to Redis and
# Timescale (see docker-compose.phase2.yml). The `legacy` source mode
# still exists for parity-testing against the monolith image but is NEVER
# required — default Phase 2 compose leaves Gateway__LegacyBaseUrl empty
# so the legacy HttpClient is not even registered.
# Gateway__DataSource=stub
# Gateway__LegacyBaseUrl=
# Gateway__BasketId=HQQQ
# Gateway__Sources__Quote=redis
# Gateway__Sources__Constituents=redis
# Gateway__Sources__History=timescale
# Gateway__Sources__SystemHealth=aggregated

# ── Quote engine (hqqq-quote-engine) ──────────
# QuoteEngine__CheckpointPath=./data/quote-engine/checkpoint.json
# QuoteEngine__CheckpointInterval=00:00:10

# ── Persistence (hqqq-persistence) ────────────
# Persistence__SchemaBootstrapOnStart=true
# Persistence__SnapshotWriteBatchSize=128
# Persistence__RawTickWriteBatchSize=256
# Persistence__RawTickRetention=30.00:00:00
# Persistence__QuoteSnapshotRetention=365.00:00:00
# Persistence__RollupRetention=730.00:00:00

# ── Analytics (hqqq-analytics, one-shot report) ──
# Run on demand: set the window and run `dotnet run --project
# src/services/hqqq-analytics/hqqq-analytics.csproj`.
# Analytics__Mode=report
# Analytics__BasketId=HQQQ
# Analytics__StartUtc=2026-04-17T00:00:00Z
# Analytics__EndUtc=2026-04-18T00:00:00Z
# Analytics__EmitJsonPath=artifacts/hqqq-report.json
# Analytics__IncludeRawTickAggregates=false

# ── Postgres (used by docker-compose) ─────────
POSTGRES_USER=admin
POSTGRES_PASSWORD=changeme
POSTGRES_DB=hqqq

# ── Grafana (used by docker-compose) ──────────
GRAFANA_ADMIN_USER=admin
GRAFANA_ADMIN_PASSWORD=changeme

# ══════════════════════════════════════════════
# Phase 2 — Azure deploy parameters (DOCS ONLY)
# ══════════════════════════════════════════════
# This block is documentation-only. The Phase 2 Azure deploy
# (infra/azure/main.bicep + .github/workflows/phase2-deploy.yml)
# does NOT read this .env file. The names below are the GitHub
# Environment secrets / repo variables consumed by the deploy
# workflow, listed here so a developer can grep the same names
# in one place. Real values must NEVER be committed.
#
# Repo secrets (used by phase2-images.yml + phase2-deploy.yml):
#   AZURE_CLIENT_ID                # OIDC federated app registration
#   AZURE_TENANT_ID
#   AZURE_SUBSCRIPTION_ID
#
# Repo variables (optional; defaults baked into workflows match
# the demo .bicepparam names):
#   PHASE2_ACR_NAME                # default: acrhqqqp2demo01
#   PHASE2_RESOURCE_GROUP          # default: rg-hqqq-p2-demo-eus-01
#   PHASE2_LOCATION                # default: eastus
#
# GitHub Environment 'phase2-demo' secrets (Bicep @secure() params):
#   KAFKA_BOOTSTRAP_SERVERS        -> Bicep param kafkaBootstrapServers
#                                  -> container env Kafka__BootstrapServers
#   KAFKA_SECURITY_PROTOCOL        -> Bicep param kafkaSecurityProtocol
#                                  -> container env Kafka__SecurityProtocol
#   KAFKA_SASL_MECHANISM           -> Bicep param kafkaSaslMechanism
#                                  -> container env Kafka__SaslMechanism
#   KAFKA_SASL_USERNAME            -> Bicep param kafkaSaslUsername
#                                  -> container env Kafka__SaslUsername
#   KAFKA_SASL_PASSWORD            -> Bicep param kafkaSaslPassword
#                                  -> container env Kafka__SaslPassword
#   REDIS_CONFIGURATION            -> Bicep param redisConfiguration
#                                  -> container env Redis__Configuration
#   TIMESCALE_CONNECTION_STRING    -> Bicep param timescaleConnectionString
#                                  -> container env Timescale__ConnectionString
#   TIINGO_API_KEY                 -> Bicep param tiingoApiKey
#                                  -> container env Tiingo__ApiKey (ingress only)
#                                  -> required for Phase 2 runtime (no stub path)
#
# See infra/azure/README.md for the bootstrap commands (resource
# group, federated credential, role assignments) and
# docs/phase2/azure-deploy.md for the operator walkthrough.

# ══════════════════════════════════════════════
# Legacy flat keys (Phase 1 / hqqq-api only)
# ══════════════════════════════════════════════
# The keys below are consumed only by the legacy hqqq-api monolith
# via its EnvironmentVariableMapper. Phase 2 services do NOT require
# these keys — they bind directly to the hierarchical sections above.
# Retained here for developers who still run the monolith for
# reference; the Phase 2 runtime does NOT need it.
#
# TIINGO_API_KEY           → now Tiingo__ApiKey
# TIINGO_WS_URL            → now Tiingo__WsUrl
# TIINGO_REST_BASE_URL     → now Tiingo__RestBaseUrl
# KAFKA_BOOTSTRAP_SERVERS  → now Kafka__BootstrapServers
# REDIS_CONFIGURATION      → now Redis__Configuration
# HQQQ_ENABLE_LIVE_MODE    → legacy only
# HQQQ_ALLOWED_ORIGINS     → legacy only
# ALPHA_VANTAGE_API_KEY    → legacy only
