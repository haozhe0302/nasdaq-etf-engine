# ── PostgreSQL / TimescaleDB ─────────────────
POSTGRES_USER=admin
POSTGRES_PASSWORD=changeme
POSTGRES_DB=hqqq

# ── Grafana ──────────────────────────────────
GRAFANA_ADMIN_USER=admin
GRAFANA_ADMIN_PASSWORD=changeme

# ── Tiingo Market Data ──────────────────────
TIINGO_API_KEY=YOUR_TIINGO_API_KEY_HERE
TIINGO_WS_URL=wss://api.tiingo.com/iex
TIINGO_REST_BASE_URL=https://api.tiingo.com/iex
TIINGO_REST_POLLING_INTERVAL_SECONDS=5
TIINGO_STALE_AFTER_SECONDS=5

# ── Alpha Vantage ────────────────────────────
# Free tier key for ETF_PROFILE endpoint
# Get yours at https://www.alphavantage.co/support/#api-key
ALPHA_VANTAGE_API_KEY=YOUR_ALPHA_VANTAGE_API_KEY_HERE

# ── HQQQ Engine ─────────────────────────────
HQQQ_ENABLE_LIVE_MODE=true
HQQQ_ENABLE_MOCK_FALLBACK=false
HQQQ_MARKET_TIME_ZONE=America/New_York
HQQQ_BASKET_CACHE_FILE=data/basket-cache.json
HQQQ_SCALE_STATE_FILE=data/scale-state.json
HQQQ_QUOTE_BROADCAST_INTERVAL_MS=1000
HQQQ_SERIES_CAPACITY=120
