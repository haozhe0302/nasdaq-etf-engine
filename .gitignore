## nasdaq-etf-engine .gitignore

# ── Secrets & Environment ────────────────────
.env
.env.local
.env.*.local

# ── OS ───────────────────────────────────────
.DS_Store
Thumbs.db
Desktop.ini
ehthumbs.db

# ── IDE / Editor ─────────────────────────────
.vs/
.vscode/
.idea/
.cursorignore
*.suo
*.user
*.DotSettings.user
*.swp
*.swo
*~

# ── Node / Frontend ──────────────────────────
node_modules/
dist/
.vite/
.cache/
*.tsbuildinfo
coverage/
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
.eslintcache

# ── .NET build output ───────────────────────
[Dd]ebug/
[Dd]ebugPublic/
[Rr]elease/
[Rr]eleases/
x64/
x86/
[Ww][Ii][Nn]32/
[Aa][Rr][Mm]/
[Aa][Rr][Mm]64/
bld/
[Bb]in/
[Oo]bj/
[Ll]og/
[Ll]ogs/
artifacts/
project.lock.json
project.fragment.lock.json

# ── NuGet ────────────────────────────────────
*.nupkg
*.snupkg

# ── MSBuild ──────────────────────────────────
*.binlog
[Bb]uild[Ll]og.*

# ── Test results ─────────────────────────────
[Tt]est[Rr]esult*/
CodeCoverage/
*.VisualState.xml
TestResult.xml
nunit-*.xml

# ── ASP.NET ──────────────────────────────────
ScaffoldingReadMe.txt

# ── Local data / state ──────────────────────
data/

# ── Temp files ───────────────────────────────
~$*
*.tmp

# ── Bicep build artifacts ────────────────────
# `az bicep build` / `az bicep build-params` emit ARM JSON next to
# the source. We compile in CI/CD but never commit the output.
infra/azure/**/*.json
