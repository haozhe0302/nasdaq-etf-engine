         integration test that bridges reference-data → ingress
         in-process. -->
    <InternalsVisibleTo Include="Hqqq.Ingress.Tests" />
    <InternalsVisibleTo Include="Hqqq.ReferenceData.Tests" />
  </ItemGroup>

</Project>
