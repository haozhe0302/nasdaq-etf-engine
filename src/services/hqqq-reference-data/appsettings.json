{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "AllowedHosts": "*",
  "Kafka": {},
  "Redis": {},
  "Timescale": {},
  "OperatingMode": "Standalone",
  "ReferenceData": {
    "SeedPath": null,
    "LiveHoldings": {
      "SourceType": "None",
      "FilePath": null,
      "HttpUrl": null,
      "HttpTimeoutSeconds": 10,
      "StaleAfterHours": 0
    },
    "Refresh": {
      "IntervalSeconds": 600,
      "RepublishIntervalSeconds": 300,
      "StartupMaxWaitSeconds": 30
    },
    "Validation": {
      "Strict": true,
      "MinConstituents": 50,
      "MaxConstituents": 150
    },
    "Publish": {
      "TopicName": null
    },
    "PublishHealth": {
      "FirstActivationGraceSeconds": 60,
      "DegradedAfterConsecutiveFailures": 1,
      "UnhealthyAfterConsecutiveFailures": 5,
      "MaxSilenceSeconds": 900
    },
    "CorporateActions": {
      "LookbackDays": 365,
      "AllowOfflineOnlyInProduction": false,
      "File": {
        "Path": null
      },
      "Tiingo": {
        "Enabled": false,
        "ApiKey": null,
        "BaseUrl": "https://api.tiingo.com/tiingo/daily",
        "TimeoutSeconds": 10,
        "MaxConcurrency": 5,
        "CacheTtlMinutes": 60
      }
    },
    "Basket": {
      "Mode": "RealSource",
      "AllowDeterministicSeedInProduction": false,
      "MarketTimeZone": "America/New_York",
      "Sources": {
        "AlphaVantage": {
          "Enabled": false,
          "BaseUrl": "https://www.alphavantage.co/query",
          "ApiKey": null,
          "TimeoutSeconds": 10
        },
        "Nasdaq": {
          "Enabled": true,
          "Url": "https://api.nasdaq.com/api/quote/list-type/nasdaq100",
          "TimeoutSeconds": 10
        }
      },
      "Schedule": {
        "FetchTimeLocal": "08:00",
        "MergeTimeLocal": "08:30",
        "ActivateTimeLocal": "09:30"
      },
      "Cache": {
        "RawCacheDir": "data/raw",
        "MergedCacheFilePath": "data/basket-cache.json"
      }
    }
  }
}
