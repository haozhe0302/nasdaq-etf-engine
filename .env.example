# ══════════════════════════════════════════════
# HQQQ MVP — Environment Variables
# ══════════════════════════════════════════════
# Copy this file to .env and fill in real API keys.
# All other values have sensible defaults.

# ── Tiingo Market Data (required) ───────────
TIINGO_API_KEY=YOUR_TIINGO_API_KEY_HERE
TIINGO_WS_URL=wss://api.tiingo.com/iex
TIINGO_REST_BASE_URL=https://api.tiingo.com/iex
TIINGO_REST_POLLING_INTERVAL_SECONDS=5
TIINGO_STALE_AFTER_SECONDS=5

# ── Alpha Vantage (required for full hybrid basket) ──
# Free tier key — get yours at https://www.alphavantage.co/support/#api-key
ALPHA_VANTAGE_API_KEY=YOUR_ALPHA_VANTAGE_API_KEY_HERE

# ── HQQQ Engine ─────────────────────────────
HQQQ_ENABLE_LIVE_MODE=true
HQQQ_ENABLE_MOCK_FALLBACK=false
HQQQ_MARKET_TIME_ZONE=America/New_York
HQQQ_ALLOWED_ORIGINS=http://localhost:5173,http://localhost:3000

# ── Basket Construction ─────────────────────
HQQQ_BASKET_CACHE_FILE=data/basket-cache.json
HQQQ_BASKET_RAW_CACHE_DIR=data/raw
HQQQ_BASKET_MERGED_HISTORY_DIR=data/merged
HQQQ_BASKET_REFRESH_TIME=08:00

# ── Pricing / Scale State ───────────────────
HQQQ_SCALE_STATE_FILE=data/scale-state.json
HQQQ_SERIES_FILE=data/series.json
HQQQ_QUOTE_BROADCAST_INTERVAL_MS=1000
HQQQ_SERIES_CAPACITY=5000

# ══════════════════════════════════════════════
# Future-phase infrastructure (not used by MVP)
# These are only needed if you run docker-compose.yml
# ══════════════════════════════════════════════
# POSTGRES_USER=admin
# POSTGRES_PASSWORD=changeme
# POSTGRES_DB=hqqq
# GRAFANA_ADMIN_USER=admin
# GRAFANA_ADMIN_PASSWORD=changeme
