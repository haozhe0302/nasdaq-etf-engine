# ══════════════════════════════════════════════
# HQQQ Phase 2 — Environment Variables
# ══════════════════════════════════════════════
# Copy this file to .env and fill in real values.
# All other values have sensible local-dev defaults.
#
# Phase 2 services use .NET hierarchical configuration
# with __ (double-underscore) as the section separator.
# Example: Tiingo__ApiKey maps to { "Tiingo": { "ApiKey": "..." } }

# ── Tiingo Market Data ────────────────────────
Tiingo__ApiKey=YOUR_TIINGO_API_KEY_HERE
Tiingo__WsUrl=wss://api.tiingo.com/iex
Tiingo__RestBaseUrl=https://api.tiingo.com/iex
Tiingo__RestPollingIntervalSeconds=5
Tiingo__ReconnectBaseDelaySeconds=2

# ── Kafka ─────────────────────────────────────
Kafka__BootstrapServers=localhost:9092
Kafka__ClientId=hqqq-local
Kafka__ConsumerGroupPrefix=hqqq

# ── Redis ─────────────────────────────────────
Redis__Configuration=localhost:6379

# ── TimescaleDB ───────────────────────────────
Timescale__ConnectionString=Host=localhost;Port=5432;Database=hqqq;Username=admin;Password=changeme

# ── Gateway (hqqq-gateway) ────────────────────
# Global fallback for endpoints with no per-endpoint override.
# Allowed: stub | legacy | (empty → auto-detect: legacy if LegacyBaseUrl is
# set and env is Development, otherwise stub).
# Gateway__DataSource=stub
# Gateway__LegacyBaseUrl=http://localhost:5000
# Gateway__BasketId=HQQQ
# Per-endpoint overrides:
#   Quote / Constituents  → accept `redis` (B5)
#   History               → accepts `timescale` (C2)
#   System-health         → follows Gateway__DataSource only (stub/legacy)
# Gateway__Sources__Quote=redis
# Gateway__Sources__Constituents=redis
# Gateway__Sources__History=timescale

# ── Quote engine (hqqq-quote-engine) ──────────
# File-based engine checkpoint for crash recovery. In containers map
# CheckpointPath to a persistent volume so state survives restarts.
# QuoteEngine__CheckpointPath=./data/quote-engine/checkpoint.json
# QuoteEngine__CheckpointInterval=00:00:10

# ── Persistence (hqqq-persistence, C3) ────────
# Kafka → TimescaleDB writer. Schema + rollup + retention bootstrap is
# idempotent; disable only in environments where schema is owned
# externally. Retention values use .NET TimeSpan format (d.hh:mm:ss) —
# sub-day windows are supported.
# Persistence__SchemaBootstrapOnStart=true
# Persistence__SnapshotWriteBatchSize=128
# Persistence__RawTickWriteBatchSize=256
# Persistence__RawTickRetention=30.00:00:00
# Persistence__QuoteSnapshotRetention=365.00:00:00
# Persistence__RollupRetention=730.00:00:00

# ── Analytics (hqqq-analytics, C4 one-shot report) ──
# Run on demand: set the window and run `dotnet run --project
# src/services/hqqq-analytics/hqqq-analytics.csproj`. The process reads
# Timescale, emits a summary (and optionally a JSON artifact), then exits.
# StartUtc / EndUtc are required; empty windows exit cleanly with
# hasData=false.
# Analytics__Mode=report
# Analytics__BasketId=HQQQ
# Analytics__StartUtc=2026-04-17T00:00:00Z
# Analytics__EndUtc=2026-04-18T00:00:00Z
# Analytics__EmitJsonPath=artifacts/hqqq-report.json
# Analytics__IncludeRawTickAggregates=false

# ── Postgres (used by docker-compose) ─────────
POSTGRES_USER=admin
POSTGRES_PASSWORD=changeme
POSTGRES_DB=hqqq

# ── Grafana (used by docker-compose) ──────────
GRAFANA_ADMIN_USER=admin
GRAFANA_ADMIN_PASSWORD=changeme

# ══════════════════════════════════════════════
# Legacy flat keys (Phase 1 / hqqq-api only)
# ══════════════════════════════════════════════
# The keys below are consumed only by the legacy hqqq-api monolith
# via its EnvironmentVariableMapper. New Phase 2 services do NOT
# use these keys — they bind directly to the hierarchical sections
# above. These will be removed once the legacy API is retired.
#
# TIINGO_API_KEY           → now Tiingo__ApiKey
# TIINGO_WS_URL            → now Tiingo__WsUrl
# TIINGO_REST_BASE_URL     → now Tiingo__RestBaseUrl
# KAFKA_BOOTSTRAP_SERVERS  → now Kafka__BootstrapServers
# REDIS_CONFIGURATION      → now Redis__Configuration
# HQQQ_ENABLE_LIVE_MODE    → legacy only
# HQQQ_ALLOWED_ORIGINS     → legacy only
# ALPHA_VANTAGE_API_KEY    → legacy only
